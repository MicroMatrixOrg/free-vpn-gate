# Bind inside the container. Keep 0.0.0.0 so Docker port publishing can reach it.
LOCAL_PROXY_HOST=0.0.0.0
LOCAL_PROXY_PORT=7928
# Bind on the Docker host. 127.0.0.1 keeps the proxy private to the host.
LOCAL_PROXY_BIND_HOST=127.0.0.1

UI_HOST=0.0.0.0
UI_PORT=8787
# Use 0.0.0.0 on a VPS, or 127.0.0.1 for local-only access.
UI_BIND_HOST=0.0.0.0
UI_USERNAME=admin
UI_PASSWORD=change-me-strong-password
UI_SECRET_PATH=changeMeSecretPath

# Optional auto-switch preferences. Empty values keep the default lowest-latency selection.
PREFERRED_COUNTRY=
PREFERRED_NODE_TYPE=

# Optional: connect OpenVPN through an existing upstream proxy.
# OPENVPN_UPSTREAM_SOCKS=127.0.0.1:10808
